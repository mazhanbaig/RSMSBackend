PORT=5000
CLOUD_NAME="your-cloudinary-cloud-name"
CLOUD_API_KEY="your-cloudinary-api-key"
CLOUD_API_SECRET="your-cloudinary-api-secret"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Firebase Admin private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_DATABASE_URL="https://your-project-default-rtdb.firebaseio.com"
JAZZCASH_MERCHANT_ID="your-jazzcash-merchant-id"
JAZZCASH_PASSWORD="your-jazzcash-password"
JAZZCASH_INTEGRITY_SALT="your-jazzcash-integrity-salt"
BASE_URL="https://your-frontend.vercel.app"

# Payment feature flag — set to "true" to enable payment endpoints
PAYMENTS_ENABLED=false

# Upstash Redis for serverless-compatible rate limiting (recommended for Vercel)
# Get a free tier at https://upstash.com
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# Easypaisa credentials (for Easypaisa payment gateway)
EASYPAISA_MERCHANT_ID="your-easypaisa-merchant-id"
EASYPAISA_PASSWORD="your-easypaisa-password"
EASYPAISA_INTEGRITY_SALT="your-easypaisa-integrity-salt"
EASYPAISA_STORE_ID="your-easypaisa-store-id"

# Sentry error monitoring (optional — leave blank to disable)
# Get DSN at https://sentry.io
SENTRY_DSN="https://your-dsn@sentry.io/your-project"
SENTRY_TRACES_SAMPLE_RATE="0.1"
