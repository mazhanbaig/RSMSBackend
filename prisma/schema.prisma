// ─── Prisma Schema — BackendRSMS ────────────────────────────────────
// Maps existing Firebase RTDB structure to Neon Postgres.
// Designed per spec: Organization → User → { Client, Owner, Property, Event, Task, Transaction }
// All entities scoped by uid (Firebase Auth) for ownership and orgId for multi-tenancy.
// Cascade deletes: deleting a User removes all their related records.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Organization ───────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users          User[]
  communityPosts CommunityPost[]
}

// ─── User ───────────────────────────────────────────────────────────

model User {
  id                 String       @id @default(cuid())
  uid                String       @unique
  name               String?
  email              String       @unique
  orgId              String
  organization       Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  subscriptionStatus String?
  subscriptionExpiry DateTime?
  photoURL           String?
  provider           String?
  createdAt          DateTime     @default(now())
  role               String       @default("agent")
  isSuperAdmin       Boolean      @default(false)
  totpSecret         String?
  totpEnabled        Boolean      @default(false)

  clients      Client[]
  owners       Owner[]
  properties   Property[]
  events       Event[]
  tasks        Task[]
  transactions Transaction[]

  @@index([orgId])
  @@index([uid])

  adminAuditLogs     AdminAuditLog[]
  userSuspensions    UserSuspension[]
  approvalRequests   ApprovalRequest[] @relation("requester")
  reviewedApprovals  ApprovalRequest[] @relation("reviewer")
  invoices           Invoice[]
  activityLogs       ActivityLog[]
  communityPosts     CommunityPost[]
  communityComments  CommunityComment[]
  propertyShareLinks PropertyShareLink[]
  chatThreads        ChatThread[]
}

// ─── Admin Audit Log ────────────────────────────────────────────────

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  admin       User     @relation(fields: [adminUserId], references: [id])
  action      String
  targetType  String?
  targetId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([adminUserId])
  @@index([createdAt])
}

// ─── User Suspension ────────────────────────────────────────────────

model UserSuspension {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  reason      String
  suspendedBy String
  suspendedAt DateTime  @default(now())
  liftedAt    DateTime?
  liftedBy    String?

  @@index([userId])
}

// ─── Client ─────────────────────────────────────────────────────────

model Client {
  id    String @id @default(cuid())
  uid   String
  orgId String

  name        String
  email       String?
  phone       String?
  budgetMin   Decimal? @db.Decimal(12, 2)
  budgetMax   Decimal? @db.Decimal(12, 2)
  preferences String?
  notes         String?
  status        String?
  pipelineStage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  properties     Property[]
  events         Event[]
  tasks          Task[]
  invoices       Invoice[]
  approvalSender    ApprovalRequest[]   @relation("sender")
  approvalTarget    ApprovalRequest[]   @relation("target")
  convertedVisitors PropertyVisitor[]

  @@index([uid])
  @@index([orgId])
  @@index([userId])
}

// ─── Owner ──────────────────────────────────────────────────────────

model Owner {
  id    String @id @default(cuid())
  uid   String
  orgId String

  name  String
  email String?
  phone String?
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([uid])
  @@index([orgId])
  @@index([userId])
}

// ─── Property ───────────────────────────────────────────────────────

model Property {
  id    String @id @default(cuid())
  uid   String
  orgId String

  title        String
  description  String?
  price        Decimal? @db.Decimal(12, 2)
  status       String?
  address      String?
  city         String?
  propertyType String?
  bedrooms     Int?
  bathrooms    Int?
  featured     Boolean  @default(false)
  images       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId  String?
  owner    Owner?  @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  events     Event[]
  tasks      Task[]
  invoices   Invoice[]
  shareLinks PropertyShareLink[]

  @@index([uid])
  @@index([orgId])
  @@index([userId])
  @@index([ownerId])
  @@index([clientId])
  @@index([city])
  @@index([price])
  @@index([featured])
}

// ─── Event ──────────────────────────────────────────────────────────

model Event {
  id    String @id @default(cuid())
  uid   String
  orgId String

  title       String
  description String?
  startTime   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([uid])
  @@index([orgId])
  @@index([userId])
}

// ─── Task ───────────────────────────────────────────────────────────

model Task {
  id    String @id @default(cuid())
  uid   String
  orgId String

  title       String
  description String?
  priority    String
  completed   Boolean   @default(false)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([uid])
  @@index([orgId])
  @@index([userId])
  @@index([completed])
}

// ─── Transaction ────────────────────────────────────────────────────

model Transaction {
  id              String    @id @default(cuid())
  uid             String
  orgId           String
  txnRef          String    @unique
  amount          Decimal   @db.Decimal(12, 2)
  status          String    @default("pending")
  gateway         String
  description     String?
  gatewayResponse String?
  gatewayMessage  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  settledAt       DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([uid])
  @@index([orgId])
  @@index([userId])
  @@index([txnRef])
  @@index([status])
}

// ─── Invoice ─────────────────────────────────────────────────────────

model Invoice {
  id        String   @id @default(cuid())
  invoiceNo String   @unique
  title     String
  amount    Decimal  @db.Decimal(12, 2)
  commission Decimal @db.Decimal(12, 2)
  tax       Decimal  @db.Decimal(12, 2) @default(0)
  total     Decimal  @db.Decimal(12, 2)
  status    String   @default("draft")
  dueDate   DateTime?
  paidAt    DateTime?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String?
  client   Client?  @relation(fields: [clientId], references: [id])
  propertyId String?
  property Property? @relation(fields: [propertyId], references: [id])

  @@index([userId])
  @@index([clientId])
  @@index([propertyId])
  @@index([status])
}

// ─── Approval Request ────────────────────────────────────────────────

model ApprovalRequest {
  id          String   @id @default(cuid())
  title       String
  description String?
  targetType  String
  targetId    String?
  action      String
  payload     Json?
  status      String   @default("pending")
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requesterId String
  requester   User   @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)

  reviewerId String?
  reviewer   User?   @relation("reviewer", fields: [reviewerId], references: [id])

  clientSender  Client? @relation("sender",   fields: [senderClientId], references: [id])
  senderClientId String?

  clientTarget  Client? @relation("target",   fields: [targetClientId], references: [id])
  targetClientId String?

  @@index([requesterId])
  @@index([reviewerId])
  @@index([status])
}

// ─── Activity Log ──────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Community Post ────────────────────────────────────────────────

model CommunityPost {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  scope     String
  orgId     String?
  organization Organization? @relation(fields: [orgId], references: [id])
  title     String
  content   String
  hidden    Boolean  @default(false)
  hiddenBy  String?
  hiddenReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments CommunityComment[]

  @@index([scope])
  @@index([orgId])
}

// ─── Community Comment ─────────────────────────────────────────────

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([postId])
}

// ─── Property Share Link ──────────────────────────────────────────

model PropertyShareLink {
  id          String   @id @default(cuid())
  token       String   @unique @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  active      Boolean  @default(true)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())

  visitors  PropertyVisitor[]
  chatThreads ChatThread[]

  @@index([propertyId])
}

// ─── Property Visitor ─────────────────────────────────────────────

model PropertyVisitor {
  id           String   @id @default(cuid())
  shareLinkId  String
  shareLink    PropertyShareLink @relation(fields: [shareLinkId], references: [id])
  name         String
  phone        String
  convertedToClientId String?
  convertedToClient   Client? @relation(fields: [convertedToClientId], references: [id])
  createdAt    DateTime @default(now())

  chatThread ChatThread?

  @@index([shareLinkId])
}

// ─── Chat Thread ──────────────────────────────────────────────────

model ChatThread {
  id          String   @id @default(cuid())
  shareLinkId String
  shareLink   PropertyShareLink @relation(fields: [shareLinkId], references: [id])
  visitorId   String   @unique
  visitor     PropertyVisitor @relation(fields: [visitorId], references: [id])
  agentUserId String
  agent       User     @relation(fields: [agentUserId], references: [id])
  status      String   @default("active")
  createdAt   DateTime @default(now())

  @@index([agentUserId])
}
